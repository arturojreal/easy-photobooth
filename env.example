# -------------------------------------------------------
# easy-photobooth — Required Environment Variables
# Copy this file to .env for local development with netlify dev
# Set these in Netlify: Site Settings > Environment Variables
# -------------------------------------------------------

# Cloudinary — required when cloudStorage.enabled = true in config.js
# Find these at: https://console.cloudinary.com > Dashboard (top-right)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: override the Cloudinary upload folder (default: "photobooth", set in config.js)
# CLOUDINARY_FOLDER=your-event-name-2026
